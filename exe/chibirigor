#!/usr/bin/env ruby
# frozen_string_literal: true

$LOAD_PATH.unshift File.expand_path("../lib", __dir__)
require "chibirigor"

command = ARGV[0]
args = ARGV[1..] || []
explain = !args.delete("--explain").nil?         # also emit the fail-soft map
unreachable = !args.delete("--unreachable").nil? # also emit unreachable-arm diagnostics
verbose = !args.delete("--verbose").nil?         # trace: show every frame, including enter/literals
json = !args.delete("--json").nil?               # trace: emit the event stream as JSON
delay = nil                                      # trace: auto-play with the given delay in seconds
if (i = args.index("--delay"))
  delay = args[i + 1]&.to_f
  abort "usage: chibirigor trace --delay SEC FILE" if delay.nil?
  args.slice!(i, 2)
end
arg = args[0]

unless %w[check annotate trace].include?(command) && arg
  abort "usage: chibirigor <check [--explain] [--unreachable]|annotate|trace [--delay SEC] [--verbose] [--json]> FILE"
end

file = arg
source = File.read(file)

# Render one diagnostic as "file:line:col: [info: ]message" plus the source line and a caret.
# When severity is :info (the fail-soft map), prefix "info:" and leave the exit code untouched.
def render_diagnostic(diagnostic, file, lines)
  column = diagnostic[:column] || 0
  length = [diagnostic[:length] || 1, 1].max
  tag = diagnostic[:severity] == :info ? "info: " : ""
  puts "#{file}:#{diagnostic[:line]}:#{column + 1}: #{tag}#{diagnostic[:message]}"
  line_text = (lines[diagnostic[:line] - 1] || "").chomp
  puts "  #{line_text}"
  puts "  #{(' ' * column)}#{'^' * length}"
end

case command
when "check"
  diagnostics = Chibirigor.check(source, explain: explain, unreachable: unreachable)
  if diagnostics.empty?
    puts "No type errors"
  else
    lines = source.lines
    diagnostics.each { |d| render_diagnostic(d, file, lines) }
    # Treat :info-only (fail-soft) output as success; exit 1 only on real errors.
    exit 1 if diagnostics.any? { |d| d[:severity] != :info }
  end
when "annotate"
  Chibirigor.annotate(source).each { |a| puts "#{a[:line]}: #{a[:type]}" }
when "trace"
  events = Chibirigor.trace(source)
  if json
    require "json"
    puts JSON.pretty_generate(events)
  else
    Chibirigor::Tracer.play(source, events, delay: delay, verbose: verbose)
  end
end
